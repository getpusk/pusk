#!/usr/bin/env bash
# Pre-commit hook — content-based protection
# Blocks: private IPs, internal domains, secrets, Co-Authored-By leaks
# Install: git config core.hooksPath .githooks  (or: make init)
set -euo pipefail

ERRORS=0
err() { echo "BLOCKED: $1"; ERRORS=$((ERRORS + 1)); }

# Get staged diff (added/modified lines only)
DIFF=$(git diff --cached --diff-filter=ACMR -U0 -- ':!.githooks' ':!vendor' ':!node_modules' ':!*.lock' ':!go.sum' 2>/dev/null || true)

# ── 1. Private IPs ──
if echo "$DIFF" | grep -nE '(192\.168\.[0-9]+\.[0-9]+|10\.(0|10|20)\.[0-9]+\.[0-9]+|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]+\.[0-9]+)' | grep -v '^\-' | grep -v 'ratelimit\|isLocal\|IsLocalURL\|test.*local\|\.spec\.' | head -5; then
    err "Private IP address in staged changes"
fi

# ── 2. Internal domains ──
if echo "$DIFF" | grep -nEi '(\.internal\.|\.local:|devitway\.ru|artais\.ru|getpusk\.ru)' | grep -v '^\-' | grep -v '\.spec\.\|test\|example' | head -5; then
    err "Internal domain in staged changes"
fi

# ── 3. Co-Authored-By with real emails ──
COMMIT_MSG_FILE="${1:-}"
if [ -n "$COMMIT_MSG_FILE" ] && [ -f "$COMMIT_MSG_FILE" ]; then
    if grep -i 'Co-Authored-By:' "$COMMIT_MSG_FILE" | grep -v 'noreply@' | head -3; then
        err "Co-Authored-By with real email (use noreply@)"
    fi
fi

# ── 4. Hardcoded secrets patterns ──
if echo "$DIFF" | grep -nE '(password|secret|token|api[_-]?key)\s*[:=]\s*["\x27][^"\x27]{8,}' | grep -v '^\-' | grep -v 'test\|example\|placeholder\|fake\|dummy\|\.spec\.' | head -5; then
    err "Possible hardcoded secret in staged changes"
fi

# ── 5. .env files staged ──
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)
if echo "$STAGED_FILES" | grep -E '^\.env|deploy\.env|\.secret$|credentials' | head -3; then
    err "Sensitive file staged for commit"
fi

# ── 6. Domain linter (if available) ──
if [ -x scripts/lint-pusk.sh ]; then
    if ! scripts/lint-pusk.sh --staged 2>&1 | tail -3; then
        err "lint-pusk.sh found errors in staged files"
    fi
fi

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "Commit blocked: $ERRORS issue(s) found."
    echo "Fix the issues or use 'git commit --no-verify' to bypass (not recommended)."
    exit 1
fi
